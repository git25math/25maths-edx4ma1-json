      "stem": [
        {
          "type": "text",
          "content": "A bag contains only red beads, blue beads, green beads and yellow beads."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "The table gives the probabilities that, when a bead is taken at random from the bag, the bead will be blue or the bead will be yellow."
        },
        {
          "type": "newline"
        },
        {
          "type": "table",
          "content": "\\begin{tabular}{|l|c|c|c|c|}\n\\hline\nColour & red & blue & green & yellow \\\\\n\\hline\nProbability & & 0.24 & & 0.31 \\\\\n\\hline\n\\end{tabular}"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "The probability that the bead will be green is twice the probability that the bead will be red."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "Sofia takes at random a bead from the bag."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "She writes down the colour of the bead and puts the bead back into the bag."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "She does this 180 times."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "Work out an estimate for the number of times she takes a red bead from the bag."
        },
        {
          "type": "space"
        }
      ],
      "parts": [],
      "answer": {
        "type": "number"
      },
